{
  "name": "@saeris/plex-monitor",
  "version": "1.0.0",
  "description": "Plex webhook service that sends Discord notifications for new library additions",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "keywords": [
    "plex",
    "discord",
    "webhook",
    "notifications",
    "media"
  ],
  "homepage": "https://github.com/saeris/plex-monitor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/saeris/plex-monitor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "bin": {
    "plex-monitor": "./src/cli.ts",
    "plxm": "./src/cli.ts"
  },
  "scripts": {
    "dev": "node --import tsx/esm --watch src/cli.ts",
    "build": "vp pack",
    "start": "node src/cli.ts",
    "lint": "vp lint"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@elysiajs/node": "^1.4.5",
    "@sinclair/typebox": "^0.34.48",
    "elysia": "^1.4.25",
    "mri": "^1.2.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@saeris/eslint-config": "^3.2.4",
    "@tsdown/exe": "patch:@tsdown/exe@npm%3A0.22.0#~/.yarn/patches/@tsdown-exe-npm-0.22.0-7094487e5f.patch",
    "@types/node": "^25.2.3",
    "@varlock/bumpy": "^1.7.0",
    "msw": "^2.14.6",
    "typescript": "^5.9.3",
    "vite-plus": "latest"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=26.1.0"
  },
  "packageManager": "yarn@4.14.1"
}
