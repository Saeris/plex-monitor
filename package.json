{
  "name": "plex-monitor",
  "version": "1.0.0",
  "description": "Plex webhook service that sends Discord notifications for new content",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "deploy": "vercel --prod",
    "lint": "vp lint"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@vercel/node": "^5.6.3",
    "elysia": "^1.4.25",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@saeris/eslint-config": "^3.2.4",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3",
    "vercel": "^50.17.1",
    "vite-plus": "latest"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "bun": ">=1.0.29"
  },
  "packageManager": "yarn@4.12.0"
}
